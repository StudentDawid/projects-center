{
  "name": "wh40k-polish-league-landing-page",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/landing-pages/wh40k-polish-league-landing-page/app",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/apps/landing-pages/wh40k-polish-league-landing-page"
      ],
      "options": {
        "command": "nuxt generate && mkdir -p ../../../dist/apps/landing-pages/wh40k-polish-league-landing-page && cp -R .output/public/. ../../../dist/apps/landing-pages/wh40k-polish-league-landing-page/",
        "cwd": "apps/landing-pages/wh40k-polish-league-landing-page"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nuxt dev --port 3005 --host 127.0.0.1",
        "cwd": "apps/landing-pages/wh40k-polish-league-landing-page"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nuxt preview",
        "cwd": "apps/landing-pages/wh40k-polish-league-landing-page"
      }
    },
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nuxi prepare",
        "cwd": "apps/landing-pages/wh40k-polish-league-landing-page"
      }
    }
  },
  "tags": ["type:app", "framework:nuxt"]
}
